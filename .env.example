# NeuroRAM environment template (copy to `.env` in the repository root).
# Loaded by `neuroram/config/settings.py` via python-dotenv.

# SQLite filename inside the `db/` directory (default: neuroram.db).
NEURORAM_DB_FILENAME=neuroram.db

# History length used by analyzers that need a sliding window context.
NEURORAM_LOOKBACK_WINDOW=12

# Background OS→DB pipeline sleep between collection cycles (seconds).
NEURORAM_COLLECTION_INTERVAL_SEC=2

# Max processes sampled per cycle for memory-heavy process ranking.
NEURORAM_PROCESS_LIMIT=15

# DAA risk thresholds (RAM %): escalate WARNING / CRITICAL / EMERGENCY bands.
NEURORAM_WARNING_THRESHOLD=70
NEURORAM_CRITICAL_THRESHOLD=85
NEURORAM_EMERGENCY_THRESHOLD=93

# Heuristic sensitivity for gradual leak-style growth (percentage points).
NEURORAM_LEAK_GROWTH_THRESHOLD=7

# CORS allow-list for FastAPI (comma-separated origins, or * for dev).
NEURORAM_CORS_ORIGINS=*
